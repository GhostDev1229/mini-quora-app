<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Post</title>
    <link rel="stylesheet" href="/edit.css">
</head>
<body>

    <div class="container">

        <h1>Edit Your Post</h1>

        <form action="/posts/<%= post.id %>?_method=PATCH" method="POST">

            <label>Username</label>
            <input
                type="text"
                name="username"
                value="<%= post.username %>"
            >

            <label>Content</label>

            <textarea
                name="content"
                rows="10"
            ><%= post.content %></textarea>

            <button type="submit">
                Update Post
            </button>

        </form>

        <a href="/posts" class="back-btn">
            ← Back to Posts
        </a>

    </div>

</body>
</html>